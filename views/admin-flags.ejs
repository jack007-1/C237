<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="fw-bold">Moderation Control Panel</h1>
    <p class="text-secondary mb-0">Manage flagged listings and view campus market statistics.</p>
  </div>
</div>

<div class="row g-4 mb-5">
  <!-- E4: Admin Stats by Category -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
      <div class="card-header bg-white py-3 border-light">
        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-chart-simple text-warning me-2"></i>Listings by Category</h5>
      </div>
      <div class="card-body">
        <% if (categoryStats && categoryStats.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Category</th>
                  <th class="text-end">Listing Count</th>
                </tr>
              </thead>
              <tbody>
                <% categoryStats.forEach(stat => { %>
                  <tr>
                    <td class="text-uppercase small fw-bold text-secondary"><%= stat.category %></td>
                    <td class="text-end fw-extrabold text-dark"><%= stat.count %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted small mb-0 text-center py-3">No stats available.</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- E4: Admin Stats by Status -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
      <div class="card-header bg-white py-3 border-light">
        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-circle-info text-warning me-2"></i>Listings by Status</h5>
      </div>
      <div class="card-body">
        <% if (statusStats && statusStats.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Status</th>
                  <th class="text-end">Listing Count</th>
                </tr>
              </thead>
              <tbody>
                <% statusStats.forEach(stat => { %>
                  <tr>
                    <td>
                      <span class="badge bg-<%= stat.status === 'available' ? 'success' : (stat.status === 'reserved' ? 'warning text-dark' : 'secondary') %> text-uppercase">
                        <%= stat.status %>
                      </span>
                    </td>
                    <td class="text-end fw-extrabold text-dark"><%= stat.count %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted small mb-0 text-center py-3">No stats available.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- E3: Flag Moderation Queue -->
<div class="card border-0 shadow-sm rounded-4 bg-white">
  <div class="card-header bg-white py-3 border-light">
    <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-triangle-exclamation text-danger me-2"></i>Reported Listings Queue</h5>
  </div>
  <div class="card-body p-0">
    <% if (flags && flags.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Listing Title</th>
              <th>Status</th>
              <th>Seller</th>
              <th>Reporter</th>
              <th>Reason for Flag</th>
              <th>Date Reported</th>
              <th class="text-end pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% flags.forEach(flag => { %>
              <tr>
                <td class="ps-4">
                  <strong><a href="/listings/<%= flag.listing_id %>" class="text-dark"><%= flag.listing_title %></a></strong>
                  <span class="d-block small text-muted">Price: $<%= parseFloat(flag.price).toFixed(2) %></span>
                </td>
                <td>
                  <span class="badge bg-<%= flag.listing_status === 'available' ? 'success' : (flag.listing_status === 'reserved' ? 'warning text-dark' : 'secondary') %> text-uppercase">
                    <%= flag.listing_status %>
                  </span>
                </td>
                <td><%= flag.seller_name %></td>
                <td><strong class="text-danger"><%= flag.reporter_name %></strong></td>
                <td><span class="text-secondary font-monospace small"><%= flag.reason %></span></td>
                <td class="small text-muted"><%= new Date(flag.flagged_at).toLocaleDateString() %></td>
                <td class="text-end pe-4">
                  <div class="d-inline-flex gap-2">
                    <form action="/flags/<%= flag.flag_id %>/resolve" method="POST" class="m-0">
                      <input type="hidden" name="action" value="dismiss">
                      <button type="submit" class="btn btn-sm btn-outline-secondary">Dismiss Report</button>
                    </form>
                    <form action="/flags/<%= flag.flag_id %>/resolve" method="POST" class="m-0">
                      <input type="hidden" name="action" value="remove_listing">
                      <button type="submit" class="btn btn-sm btn-danger"><i class="fa-solid fa-trash me-1"></i>Delete Listing</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-circle-check text-success fa-3x mb-3 opacity-50"></i>
        <h5 class="fw-bold text-muted">Moderation Queue Clean</h5>
        <p class="text-muted small mb-0">No open reports from students currently pending review.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
