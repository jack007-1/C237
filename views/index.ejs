<%- include('partials/header') %>

<div class="row">
  <!-- Left Side: Search & Advanced Filters Form (F1, F2, F3, F4) -->
  <aside class="col-lg-3 mb-4">
    <div class="card shadow-sm border-0 bg-dark text-white rounded-4">
      <div class="card-header border-secondary py-3">
        <h5 class="mb-0 fw-bold"><i class="fa-solid fa-sliders me-2 text-warning"></i>Refine Search</h5>
      </div>
      <div class="card-body">
        <form action="/" method="GET">
          <!-- Keyword search (F1) -->
          <div class="mb-3">
            <label for="search" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Keyword</label>
            <div class="input-group">
              <span class="input-group-text bg-secondary border-0 text-white"><i class="fa-solid fa-font"></i></span>
              <input type="text" id="search" name="search" class="form-control bg-secondary text-white border-0" placeholder="e.g. textbook..." value="<%= filters.search %>">
            </div>
          </div>

          <!-- Category filter (F3) -->
          <div class="mb-3">
            <label for="category" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Category</label>
            <select id="category" name="category" class="form-select bg-secondary text-white border-0">
              <option value="All">All Categories</option>
              <option value="textbook" <%= filters.category === 'textbook' ? 'selected' : '' %>>Textbook</option>
              <option value="calculator" <%= filters.category === 'calculator' ? 'selected' : '' %>>Calculator</option>
              <option value="lab_coat" <%= filters.category === 'lab_coat' ? 'selected' : '' %>>Lab Coat</option>
              <option value="notes" <%= filters.category === 'notes' ? 'selected' : '' %>>Notes</option>
              <option value="electronics" <%= filters.category === 'electronics' ? 'selected' : '' %>>Electronics</option>
              <option value="others" <%= filters.category === 'others' ? 'selected' : '' %>>Others</option>
            </select>
          </div>

          <!-- Module code exact/prefix filter (F2) -->
          <div class="mb-3">
            <label for="module_code" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Module Code</label>
            <div class="input-group">
              <span class="input-group-text bg-secondary border-0 text-white"><i class="fa-solid fa-code"></i></span>
              <input type="text" id="module_code" name="module_code" class="form-control bg-secondary text-white border-0" placeholder="e.g. C237" value="<%= filters.module_code %>">
            </div>
          </div>

          <!-- Price range filter (F4) -->
          <div class="mb-3">
            <label class="form-label small text-uppercase tracking-wider fw-bold text-muted">Price Range ($)</label>
            <div class="row g-2">
              <div class="col">
                <input type="number" name="min_price" class="form-control bg-secondary text-white border-0" placeholder="Min" min="0" step="0.01" value="<%= filters.min_price %>">
              </div>
              <div class="col">
                <input type="number" name="max_price" class="form-control bg-secondary text-white border-0" placeholder="Max" min="0" step="0.01" value="<%= filters.max_price %>">
              </div>
            </div>
          </div>

          <!-- Item condition filter (F4) -->
          <div class="mb-3">
            <label for="condition" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Condition</label>
            <select id="condition" name="condition" class="form-select bg-secondary text-white border-0">
              <option value="All">All Conditions</option>
              <option value="new" <%= filters.condition === 'new' ? 'selected' : '' %>>New</option>
              <option value="like_new" <%= filters.condition === 'like_new' ? 'selected' : '' %>>Like New</option>
              <option value="used" <%= filters.condition === 'used' ? 'selected' : '' %>>Used</option>
              <option value="worn" <%= filters.condition === 'worn' ? 'selected' : '' %>>Worn</option>
            </select>
          </div>

          <!-- Sorting (F3) -->
          <div class="mb-4">
            <label for="sort" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Sort By</label>
            <select id="sort" name="sort" class="form-select bg-secondary text-white border-0">
              <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest Listed</option>
              <option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
              <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
            </select>
          </div>

          <button type="submit" class="btn btn-warning w-100 fw-bold py-2"><i class="fa-solid fa-filter me-2"></i>Filter Results</button>
          <a href="/" class="btn btn-outline-secondary w-100 mt-2 py-2 text-white">Reset Filters</a>
        </form>
      </div>
    </div>
  </aside>

  <!-- Right Side: Browse Grid (C1) -->
  <main class="col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="fw-bold mb-0">Marketplace Listings</h2>
      <span class="badge bg-secondary py-2 px-3 rounded-pill text-white"><%= listings.length %> items matching</span>
    </div>

    <% if (listings && listings.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        <% listings.forEach(listing => { %>
          <div class="col">
            <!-- Listing Card -->
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden listing-card transition-hover">
              
              <!-- Card Image / Placeholder (B2) -->
              <div class="position-relative bg-light border-bottom text-center d-flex align-items-center justify-content-center" style="height: 200px;">
                <% if (listing.image) { %>
                  <img src="/uploads/<%= listing.image %>" class="w-100 h-100 object-fit-cover" alt="<%= listing.title %>">
                <% } else { %>
                  <div class="text-muted d-flex flex-column align-items-center">
                    <i class="fa-solid fa-image fa-3x mb-2 text-secondary opacity-50"></i>
                    <span class="small text-uppercase tracking-wider fw-bold">No Image Provided</span>
                  </div>
                <% } %>
                
                <!-- Status Overlay Badge (C1) -->
                <div class="position-absolute top-0 start-0 m-3">
                  <span class="badge bg-<%= listing.status === 'available' ? 'success' : (listing.status === 'reserved' ? 'warning text-dark' : 'secondary') %> py-2 px-3 shadow">
                    <%= listing.status %>
                  </span>
                </div>

                <!-- Condition Overlay Badge -->
                <div class="position-absolute bottom-0 end-0 m-3">
                  <span class="badge bg-dark bg-opacity-75 py-2 px-3">
                    Condition: <%= listing.item_condition.replace('_', ' ') %>
                  </span>
                </div>
              </div>

              <!-- Card Body -->
              <div class="card-body d-flex flex-column justify-content-between">
                <div>
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="small text-uppercase tracking-wider text-muted fw-bold"><%= listing.category %></span>
                    <% if (listing.module_code) { %>
                      <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1"><%= listing.module_code %></span>
                    <% } %>
                  </div>
                  
                  <h5 class="card-title fw-bold text-dark mb-2"><%= listing.title %></h5>
                  <p class="card-text text-secondary small line-clamp-3 mb-3"><%= listing.description %></p>
                </div>

                <div class="border-top pt-3 mt-2">
                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fs-4 fw-extrabold text-warning">$<%= parseFloat(listing.price).toFixed(2) %></span>
                    <span class="small text-muted"><i class="fa-solid fa-circle-user me-1 text-secondary"></i><%= listing.seller_name %></span>
                  </div>
                  
                  <a href="/listings/<%= listing.id %>" class="btn btn-outline-warning text-dark w-100 fw-bold rounded-3">
                    <i class="fa-solid fa-eye me-1"></i>View Details
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <!-- Empty State -->
      <div class="text-center py-5 bg-white border border-dashed rounded-4 my-4 shadow-sm">
        <i class="fa-solid fa-store-slash text-muted fa-4x mb-3 opacity-50"></i>
        <h3 class="fw-bold">No Listings Found</h3>
        <p class="text-secondary max-width-md mx-auto mb-4">We couldn't find any textbooks or gadgets matching your active search terms or filters. Try adjusting your fields or creating a new listing!</p>
        <a href="/listings/new" class="btn btn-warning fw-bold px-4 py-2"><i class="fa-solid fa-plus me-2"></i>Create Listing</a>
      </div>
    <% } %>
  </main>
</div>
<%- include('partials/footer') %>
