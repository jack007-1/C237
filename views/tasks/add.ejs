<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="form-page-container">
  <div class="form-card">
    <div class="form-card-header">
      <i class="fa-solid fa-list-check form-header-icon text-indigo"></i>
      <h2>Add Event Task</h2>
      <p>Configure a new planning activity for <strong><%= event.title %></strong></p>
    </div>
    
    <form action="/events/<%= event.event_id %>/tasks" method="POST" class="standard-form">
      <div class="form-group">
        <label for="task_name"><i class="fa-solid fa-clipboard-list"></i> Task Title *</label>
        <input type="text" id="task_name" name="task_name" class="form-control" placeholder="e.g. Hire Wedding Band" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="assigned_to"><i class="fa-solid fa-user"></i> Assigned To *</label>
          <input type="text" id="assigned_to" name="assigned_to" class="form-control" placeholder="e.g. John or Vendor Name" required>
        </div>

        <div class="form-group">
          <label for="due_date"><i class="fa-regular fa-calendar"></i> Due Date *</label>
          <input type="date" id="due_date" name="due_date" class="form-control" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="cost"><i class="fa-solid fa-dollar-sign"></i> Estimated Cost ($) *</label>
          <input type="number" id="cost" name="cost" min="0" step="0.01" class="form-control" value="0.00" required>
        </div>

        <div class="form-group">
          <label for="status"><i class="fa-solid fa-circle-question"></i> Status *</label>
          <select id="status" name="status" class="form-control" required>
            <option value="Pending" selected>Pending</option>
            <option value="In Progress">In Progress</option>
            <option value="Completed">Completed</option>
          </select>
        </div>
      </div>

      <div class="form-actions">
        <a href="/events/<%= event.event_id %>" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Add Task</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
