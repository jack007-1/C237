<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="mb-4">
      <a href="/" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i> Back to Browse</a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4 bg-white">
      <div class="row g-0">
        <!-- Left Side: Listing Image (B2) -->
        <div class="col-md-6 bg-light d-flex align-items-center justify-content-center text-center p-3" style="min-height: 350px;">
          <% if (listing.image) { %>
            <img src="/uploads/<%= listing.image %>" class="img-fluid rounded-4 shadow-sm w-100 object-fit-contain" style="max-height: 450px;" alt="<%= listing.title %>">
          <% } else { %>
            <div class="text-muted d-flex flex-column align-items-center p-5">
              <i class="fa-solid fa-image fa-4x mb-3 text-secondary opacity-25"></i>
              <span class="small text-uppercase tracking-wider fw-bold">No Image Uploaded</span>
            </div>
          <% } %>
        </div>

        <!-- Right Side: Details & Actions (C2, D3) -->
        <div class="col-md-6">
          <div class="card-body p-4 d-flex flex-column h-100 justify-content-between">
            <div>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="badge bg-warning text-dark text-uppercase px-3 py-2 rounded-pill"><%= listing.category %></span>
                <span class="badge bg-<%= listing.status === 'available' ? 'success' : (listing.status === 'reserved' ? 'warning text-dark' : 'secondary') %> text-uppercase px-3 py-2 rounded-pill">
                  <%= listing.status %>
                </span>
              </div>

              <h1 class="card-title fw-bold text-dark mb-2"><%= listing.title %></h1>
              
              <div class="d-flex align-items-center gap-3 mb-3">
                <span class="fs-2 fw-extrabold text-warning">$<%= parseFloat(listing.price).toFixed(2) %></span>
                <% if (listing.module_code) { %>
                  <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                    Module: <%= listing.module_code %>
                  </span>
                <% } %>
                <span class="badge bg-dark bg-opacity-75 px-3 py-2">
                  Condition: <%= listing.item_condition.replace('_', ' ') %>
                </span>
              </div>

              <hr class="border-secondary border-opacity-25">

              <h6 class="fw-bold text-uppercase tracking-wider text-muted small mb-2">Description</h6>
              <p class="card-text text-secondary mb-4" style="white-space: pre-line;"><%= listing.description %></p>
              
              <hr class="border-secondary border-opacity-25">

              <!-- Gated Contact Information (C2) -->
              <h6 class="fw-bold text-uppercase tracking-wider text-muted small mb-2">Seller Contact Info</h6>
              <% if (user) { %>
                <div class="p-3 bg-light rounded-3 mb-4 border border-secondary border-opacity-10">
                  <p class="mb-1"><i class="fa-solid fa-circle-user me-2 text-warning"></i>Seller Name: <strong><%= listing.seller_name %></strong></p>
                  <p class="mb-0"><i class="fa-solid fa-address-book me-2 text-warning"></i>Contact Details: <strong><%= listing.seller_contact %></strong></p>
                </div>
              <% } else { %>
                <div class="alert alert-warning py-3 rounded-3 mb-4" role="alert">
                  <i class="fa-solid fa-lock me-2"></i>
                  Please <a href="/login" class="alert-link">log in</a> or <a href="/register" class="alert-link">register</a> to view the seller's contact details and reserve this item.
                </div>
              <% } %>
            </div>

            <!-- Action Buttons based on Role/Ownership (C2, D3) -->
            <div class="mt-4">
              <% if (user) { %>
                <% if (user.id === listing.seller_id || user.role === 'admin') { %>
                  <!-- Owner Options (D1, E1, D3 status buttons) -->
                  <div class="p-3 bg-dark bg-opacity-5 border border-secondary border-opacity-10 rounded-3 mb-3">
                    <span class="small text-muted d-block mb-2">Owner Controls:</span>
                    <div class="d-flex gap-2">
                      <a href="/listings/<%= listing.id %>/edit" class="btn btn-dark btn-sm flex-fill">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Details
                      </a>
                      <a href="/listings/<%= listing.id %>/delete" class="btn btn-outline-danger btn-sm flex-fill">
                        <i class="fa-solid fa-trash me-1"></i> Delete Listing
                      </a>
                    </div>
                  </div>

                  <!-- State Machine Action buttons for Owner (D3) -->
                  <% if (listing.status === 'reserved' && activeReservation) { %>
                    <div class="p-3 border border-warning rounded-3 bg-warning bg-opacity-5">
                      <span class="small text-dark fw-bold d-block mb-2"><i class="fa-solid fa-hand-shake me-1"></i> Reservation Confirmed by Buyer!</span>
                      <div class="d-flex gap-2">
                        <form action="/listings/<%= listing.id %>/status" method="POST" class="flex-fill">
                          <input type="hidden" name="action" value="confirm_sale">
                          <button type="submit" class="btn btn-success btn-sm w-100">
                            <i class="fa-solid fa-check me-1"></i> Confirm Sale
                          </button>
                        </form>
                        <form action="/listings/<%= listing.id %>/status" method="POST" class="flex-fill">
                          <input type="hidden" name="action" value="release_reservation">
                          <button type="submit" class="btn btn-outline-dark btn-sm w-100">
                            <i class="fa-solid fa-xmark me-1"></i> Release Reservation
                          </button>
                        </form>
                      </div>
                    </div>
                  <% } %>

                <% } else { %>
                  <!-- Buyer Options (D3 reserve, E2 flag) -->
                  <% if (listing.status === 'available') { %>
                    <form action="/listings/<%= listing.id %>/reserve" method="POST" class="mb-3">
                      <button type="submit" class="btn btn-warning btn-lg text-dark fw-bold w-100 rounded-3">
                        <i class="fa-solid fa-bookmark me-1"></i> Reserve This Item
                      </button>
                    </form>
                  <% } else if (listing.status === 'reserved') { %>
                    <div class="alert alert-secondary py-3 text-center mb-3">
                      <i class="fa-solid fa-hourglass-half me-1"></i> This item is reserved by another student. Deal pending.
                    </div>
                  <% } else if (listing.status === 'sold') { %>
                    <div class="alert alert-dark py-3 text-center mb-3">
                      <i class="fa-solid fa-circle-check me-1"></i> This item has been sold.
                    </div>
                  <% } %>

                  <!-- Flag listing form (E2) -->
                  <div class="border-top pt-3 mt-3">
                    <button class="btn btn-sm btn-outline-danger w-100 rounded-3 text-start" type="button" data-bs-toggle="collapse" data-bs-target="#flagCollapse" aria-expanded="false" aria-controls="flagCollapse">
                      <i class="fa-solid fa-flag me-1"></i> Report / Flag Listing
                    </button>
                    <div class="collapse mt-2" id="flagCollapse">
                      <div class="card card-body border-danger bg-danger bg-opacity-5 p-3">
                        <form action="/listings/<%= listing.id %>/flag" method="POST">
                          <div class="mb-2">
                            <label for="reason" class="form-label small text-danger fw-bold mb-1">Reason for Flagging</label>
                            <input type="text" id="reason" name="reason" class="form-control form-control-sm border-danger" placeholder="e.g. Inappropriate item, incorrect info" required>
                          </div>
                          <button type="submit" class="btn btn-danger btn-sm px-3">Submit Report</button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% } %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
