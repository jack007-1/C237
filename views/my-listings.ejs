<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="fw-bold">My Listings Dashboard</h1>
    <p class="text-secondary mb-0">Track and manage items you are selling on campus.</p>
  </div>
  <a href="/listings/new" class="btn btn-warning fw-bold text-dark"><i class="fa-solid fa-plus me-1"></i> Add New Listing</a>
</div>

<!-- Personalized counts per status - GROUP BY (C3) -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card shadow-sm border-0 bg-success text-white rounded-4">
      <div class="card-body py-3 d-flex align-items-center justify-content-between">
        <div>
          <h6 class="text-uppercase small tracking-wider opacity-75 fw-bold mb-1">Available Listings</h6>
          <h2 class="fw-extrabold mb-0"><%= statusCounts.available %></h2>
        </div>
        <i class="fa-solid fa-store fa-2x opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm border-0 bg-warning text-dark rounded-4">
      <div class="card-body py-3 d-flex align-items-center justify-content-between">
        <div>
          <h6 class="text-uppercase small tracking-wider opacity-75 fw-bold mb-1">Reserved Deals</h6>
          <h2 class="fw-extrabold mb-0"><%= statusCounts.reserved %></h2>
        </div>
        <i class="fa-solid fa-handshake fa-2x opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm border-0 bg-secondary text-white rounded-4">
      <div class="card-body py-3 d-flex align-items-center justify-content-between">
        <div>
          <h6 class="text-uppercase small tracking-wider opacity-75 fw-bold mb-1">Sold Archive</h6>
          <h2 class="fw-extrabold mb-0"><%= statusCounts.sold %></h2>
        </div>
        <i class="fa-solid fa-circle-check fa-2x opacity-50"></i>
      </div>
    </div>
  </div>
</div>

<!-- Listings Table/Grid (C3) -->
<div class="card border-0 shadow-sm rounded-4 bg-white">
  <div class="card-header border-light py-3 bg-white">
    <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-list me-2 text-warning"></i>My Market Listings</h5>
  </div>
  <div class="card-body p-0">
    <% if (listings && listings.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Preview</th>
              <th>Title</th>
              <th>Category</th>
              <th>Module</th>
              <th>Price</th>
              <th>Status</th>
              <th>Date Created</th>
              <th class="text-end pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% listings.forEach(item => { %>
              <tr>
                <td class="ps-4">
                  <div class="bg-light rounded d-flex align-items-center justify-content-center text-center" style="width: 50px; height: 50px; overflow: hidden;">
                    <% if (item.image) { %>
                      <img src="/uploads/<%= item.image %>" class="w-100 h-100 object-fit-cover" alt="<%= item.title %>">
                    <% } else { %>
                      <i class="fa-solid fa-image text-secondary opacity-50 small"></i>
                    <% } %>
                  </div>
                </td>
                <td>
                  <strong><a href="/listings/<%= item.id %>" class="text-dark"><%= item.title %></a></strong>
                  <span class="d-block small text-muted text-truncate" style="max-width: 250px;"><%= item.description %></span>
                </td>
                <td class="text-uppercase small"><%= item.category %></td>
                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25"><%= item.module_code || 'N/A' %></span></td>
                <td class="fw-bold">$<%= parseFloat(item.price).toFixed(2) %></td>
                <td>
                  <span class="badge bg-<%= item.status === 'available' ? 'success' : (item.status === 'reserved' ? 'warning text-dark' : 'secondary') %> text-uppercase">
                    <%= item.status %>
                  </span>
                </td>
                <td class="small text-muted"><%= new Date(item.created_at).toLocaleDateString() %></td>
                <td class="text-end pe-4">
                  <div class="d-inline-flex gap-2">
                    <a href="/listings/<%= item.id %>/edit" class="btn btn-sm btn-outline-dark" title="Edit Listing">
                      <i class="fa-solid fa-pen-to-square"></i>
                    </a>
                    <a href="/listings/<%= item.id %>/delete" class="btn btn-sm btn-outline-danger" title="Delete Listing">
                      <i class="fa-solid fa-trash"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="fa-solid fa-store fa-3x text-muted opacity-25 mb-3"></i>
        <h5 class="fw-bold text-muted">No Listings Yet</h5>
        <p class="text-muted small mb-4">Start selling your textbook or calculator now!</p>
        <a href="/listings/new" class="btn btn-warning btn-sm fw-bold text-dark px-4 py-2"><i class="fa-solid fa-plus me-1"></i>List Item</a>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
