<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="form-page-container">
  <div class="form-card">
    <div class="form-card-header">
      <i class="fa-solid fa-calendar-plus form-header-icon text-indigo"></i>
      <h2>Create New Event</h2>
      <p>Fill in the details below to initialize your event planner</p>
    </div>
    
    <form action="/events" method="POST" class="standard-form">
      <div class="form-group">
        <label for="title"><i class="fa-solid fa-heading"></i> Event Title *</label>
        <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Annual Gala Dinner" required>
      </div>

      <div class="form-group">
        <label for="description"><i class="fa-solid fa-align-left"></i> Description / Notes</label>
        <textarea id="description" name="description" class="form-control" rows="4" placeholder="Brief details about the event..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="event_date"><i class="fa-regular fa-calendar"></i> Date *</label>
          <input type="date" id="event_date" name="event_date" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="event_time"><i class="fa-regular fa-clock"></i> Time *</label>
          <input type="time" id="event_time" name="event_time" class="form-control" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="category"><i class="fa-solid fa-tags"></i> Category *</label>
          <select id="category" name="category" class="form-control" required>
            <option value="" disabled selected>Select Category</option>
            <option value="Wedding">Wedding</option>
            <option value="Birthday">Birthday</option>
            <option value="Corporate">Corporate</option>
            <option value="Social">Social</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="budget"><i class="fa-solid fa-wallet"></i> Estimated Budget ($) *</label>
          <input type="number" id="budget" name="budget" min="0" step="0.01" class="form-control" placeholder="0.00" required>
        </div>
      </div>

      <div class="form-group">
        <label for="location"><i class="fa-solid fa-location-dot"></i> Venue / Location *</label>
        <input type="text" id="location" name="location" class="form-control" placeholder="e.g. Marina Bay Sands, Hall A" required>
      </div>

      <div class="form-actions">
        <a href="/events" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Event</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
