<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="detail-header-section flex-between">
  <div>
    <div class="detail-badge-row">
      <span class="event-category-badge"><%= event.category %></span>
      <span class="badge badge-<%= event.status.toLowerCase() %>"><%= event.status %></span>
    </div>
    <h1><%= event.title %></h1>
    <p class="subtitle"><i class="fa-solid fa-location-dot"></i> <%= event.location %> &bull; <i class="fa-solid fa-calendar"></i> <%= new Date(event.event_date).toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %> at <%= event.event_time.substring(0,5) %></p>
  </div>
  
  <div class="detail-header-actions no-print">
    <button onclick="window.print()" class="btn btn-outline">
      <i class="fa-solid fa-print"></i> Print Brief
    </button>
    <a href="/events/<%= event.event_id %>/edit" class="btn btn-indigo">
      <i class="fa-solid fa-pen-to-square"></i> Edit Event
    </a>
    <a href="/events/<%= event.event_id %>/delete" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this event?')">
      <i class="fa-solid fa-trash"></i> Delete
    </a>
  </div>
</div>

<div class="event-detail-grid">
  <!-- Left Side: Event Info, Budget Card, and Budget Chart -->
  <div class="detail-left-col">
    <!-- Description Card -->
    <div class="card detail-desc-card">
      <div class="card-header">
        <h3><i class="fa-solid fa-file-invoice"></i> Event Description</h3>
      </div>
      <div class="card-body">
        <p class="desc-text"><%= event.description || 'No description provided for this event.' %></p>
      </div>
    </div>

    <!-- Budget Tracking Gauge -->
    <div class="card budget-card">
      <div class="card-header flex-between">
        <h3><i class="fa-solid fa-wallet"></i> Budget Breakdown</h3>
        <span class="budget-status <%= remainingBudget < 0 ? 'text-danger font-bold' : 'text-success' %>">
          <%= remainingBudget < 0 ? 'OVER BUDGET' : 'UNDER BUDGET' %>
        </span>
      </div>
      <div class="card-body">
        <div class="budget-gauge-row">
          <div class="gauge-item">
            <span class="gauge-label">Total Allocated</span>
            <span class="gauge-value">$<%= parseFloat(event.budget).toLocaleString(undefined, {minimumFractionDigits: 2}) %></span>
          </div>
          <div class="gauge-item">
            <span class="gauge-label">Cumulative Spent</span>
            <span class="gauge-value spent-value">$<%= totalSpent.toLocaleString(undefined, {minimumFractionDigits: 2}) %></span>
          </div>
          <div class="gauge-item">
            <span class="gauge-label">Remaining Savings</span>
            <span class="gauge-value <%= remainingBudget < 0 ? 'text-danger' : 'text-success' %>">
              $<%= remainingBudget.toLocaleString(undefined, {minimumFractionDigits: 2}) %>
            </span>
          </div>
        </div>

        <div class="progress-bar-label flex-between margin-top-sm">
          <span>Budget Utilization Progress</span>
          <span><%= budgetProgressPercent %>%</span>
        </div>
        <div class="progress-bar-container large">
          <div class="progress-bar <%= remainingBudget < 0 ? 'bg-danger' : 'bg-emerald' %>" style="width: <%= budgetProgressPercent %>%;"></div>
        </div>

        <% if (remainingBudget < 0) { %>
          <div class="alert alert-danger margin-top-sm no-margin-bottom">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>Warning: Combined expenses exceed your allocated event budget by <strong>$<%= Math.abs(remainingBudget).toLocaleString() %></strong>!</span>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Specific Event Chart Card -->
    <div class="card chart-card no-print">
      <div class="card-header">
        <h3>Expense Distribution per Task</h3>
      </div>
      <div class="card-body">
        <% if (tasks && tasks.length > 0) { %>
          <div class="chart-container-sm">
            <canvas id="eventExpensesChart"></canvas>
          </div>
        <% } else { %>
          <p class="text-muted text-center py-4">Add tasks with costs to see the cost breakdown chart.</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Side: Task Checklist (CRUD) -->
  <div class="detail-right-col">
    <div class="card tasks-card">
      <div class="card-header flex-between">
        <h3><i class="fa-solid fa-list-check"></i> Activity & Task Checklist</h3>
        <a href="/events/<%= event.event_id %>/tasks/new" class="btn btn-success btn-sm no-print">
          <i class="fa-solid fa-plus"></i> Add Task
        </a>
      </div>
      <div class="card-body">
        <% if (tasks && tasks.length > 0) { %>
          <div class="tasks-table-wrapper">
            <table class="tasks-table">
              <thead>
                <tr>
                  <th>Task Title</th>
                  <th>Assignee</th>
                  <th>Due Date</th>
                  <th>Expense</th>
                  <th>Status</th>
                  <th class="no-print">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% tasks.forEach(task => { %>
                  <tr>
                    <td><strong><%= task.task_name %></strong></td>
                    <td><%= task.assigned_to %></td>
                    <td><%= new Date(task.due_date).toLocaleDateString() %></td>
                    <td>$<%= parseFloat(task.cost).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                    <td>
                      <span class="badge badge-<%= task.status.toLowerCase().replace(' ', '-') %>"><%= task.status %></span>
                    </td>
                    <td class="table-actions no-print">
                      <a href="/tasks/<%= task.task_id %>/edit" class="btn btn-xs btn-outline" title="Edit Task">
                        <i class="fa-solid fa-pencil"></i>
                      </a>
                      <a href="/tasks/<%= task.task_id %>/delete" class="btn btn-xs btn-danger" onclick="return confirm('Are you sure you want to delete this task?')" title="Delete Task">
                        <i class="fa-solid fa-trash"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="fa-solid fa-clipboard-question empty-icon"></i>
            <p>No tasks configured for this event yet.</p>
            <a href="/events/<%= event.event_id %>/tasks/new" class="btn btn-outline btn-sm margin-top-xs">Add First Task</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Printable View Extra (Only visible on print) -->
<div class="print-only-footer">
  <hr>
  <p>PlanIt Briefing Summary Generated on <%= new Date().toLocaleString() %>.</p>
</div>

<!-- Task Expenses Script -->
<% if (tasks && tasks.length > 0) { %>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      // Load task data
      const tasksData = <%- JSON.stringify(tasks) %>;
      const labels = tasksData.map(t => t.task_name);
      const costs = tasksData.map(t => parseFloat(t.cost));

      const ctx = document.getElementById('eventExpensesChart').getContext('2d');
      new Chart(ctx, {
        type: 'pie',
        data: {
          labels: labels,
          datasets: [{
            data: costs,
            backgroundColor: [
              'rgba(99, 102, 241, 0.8)',
              'rgba(236, 72, 153, 0.8)',
              'rgba(16, 185, 129, 0.8)',
              'rgba(245, 158, 11, 0.8)',
              'rgba(14, 165, 233, 0.8)',
              'rgba(168, 85, 247, 0.8)'
            ],
            borderColor: '#1e1b4b',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: {
                color: '#94a3b8',
                font: { family: 'Outfit', size: 11 }
              }
            }
          }
        }
      });
    });
  </script>
<% } %>

<%- include('../partials/footer') %>
