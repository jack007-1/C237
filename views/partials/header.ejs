<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'RPMarket' %> - RP Student Marketplace</title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Google Fonts & FontAwesome -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Chart.js (for Admin Statistics) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Custom CSS overrides for premium aesthetics -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

  <!-- Role-Aware Bootstrap 5 Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <i class="fa-solid fa-shop me-2 text-warning logo-icon-spin"></i>
        <span class="fw-bold tracking-tight">RP<span class="text-warning">Market</span></span>
      </a>
      
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarContent">
        <!-- Search bar directly in navbar - Signature Feature (F2) -->
        <form action="/" method="GET" class="d-flex mx-auto my-2 my-lg-0 w-50">
          <div class="input-group">
            <input type="text" name="module_code" class="form-control" placeholder="Search by Module Code (e.g. C237)..." value="<%= typeof filters !== 'undefined' ? filters.module_code : '' %>">
            <button class="btn btn-warning" type="submit">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </div>
        </form>

        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
          <li class="nav-item">
            <a class="nav-link" href="/"><i class="fa-solid fa-house me-1"></i> Browse</a>
          </li>
          
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/listings/new"><i class="fa-solid fa-circle-plus me-1"></i> Sell</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/my-listings"><i class="fa-solid fa-table-columns me-1"></i> My Listings</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/my-reservations"><i class="fa-solid fa-bookmark me-1"></i> Reservations</a>
            </li>

            <% if (user.role === 'admin') { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-warning" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fa-solid fa-user-shield me-1"></i> Admin Panel
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                  <li><a class="dropdown-item" href="/admin/flags"><i class="fa-solid fa-triangle-exclamation text-danger me-2"></i> Moderation Queue</a></li>
                </ul>
              </li>
            <% } %>

            <li class="nav-item ms-lg-3">
              <span class="navbar-text text-white me-3 d-none d-lg-inline">
                Welcome, <strong class="text-warning"><%= user.username %></strong>
              </span>
            </li>
            <li class="nav-item">
              <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
            </li>
          <% } else { %>
            <li class="nav-item ms-lg-3">
              <a class="btn btn-outline-warning btn-sm me-2" href="/login">Login</a>
            </li>
            <li class="nav-item">
              <a class="btn btn-warning btn-sm text-dark fw-bold" href="/register">Register</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Main Container -->
  <div class="container my-4" style="min-height: calc(100vh - 180px);">
    
    <!-- Render Flash Messages -->
    <%- include('flash') %>
