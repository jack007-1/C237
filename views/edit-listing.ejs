<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="mb-4">
      <a href="/listings/<%= listing.id %>" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i> Cancel & Back</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 bg-white mb-5">
      <div class="card-header border-light py-3 bg-white text-center">
        <i class="fa-solid fa-pen-to-square text-warning fa-3x mb-2"></i>
        <h2 class="fw-bold text-dark">Edit Listing Details</h2>
        <p class="text-secondary small mb-0">Modify information for <strong>"<%= listing.title %>"</strong>.</p>
      </div>
      <div class="card-body p-4">
        
        <form action="/listings/<%= listing.id %>/edit" method="POST" enctype="multipart/form-data">
          
          <div class="mb-3">
            <label for="title" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Item Title *</label>
            <input type="text" id="title" name="title" class="form-control" value="<%= listing.title %>" required>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Detailed Description *</label>
            <textarea id="description" name="description" class="form-control" rows="4" required><%= listing.description %></textarea>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="category" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Category *</label>
              <select id="category" name="category" class="form-select" required>
                <option value="textbook" <%= listing.category === 'textbook' ? 'selected' : '' %>>Textbook</option>
                <option value="calculator" <%= listing.category === 'calculator' ? 'selected' : '' %>>Calculator</option>
                <option value="lab_coat" <%= listing.category === 'lab_coat' ? 'selected' : '' %>>Lab Coat</option>
                <option value="notes" <%= listing.category === 'notes' ? 'selected' : '' %>>Notes</option>
                <option value="electronics" <%= listing.category === 'electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="others" <%= listing.category === 'others' ? 'selected' : '' %>>Others</option>
              </select>
            </div>

            <div class="col-md-6">
              <label for="item_condition" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Item Condition *</label>
              <select id="item_condition" name="item_condition" class="form-select" required>
                <option value="new" <%= listing.item_condition === 'new' ? 'selected' : '' %>>New</option>
                <option value="like_new" <%= listing.item_condition === 'like_new' ? 'selected' : '' %>>Like New</option>
                <option value="used" <%= listing.item_condition === 'used' ? 'selected' : '' %>>Used</option>
                <option value="worn" <%= listing.item_condition === 'worn' ? 'selected' : '' %>>Worn</option>
              </select>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="price" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Price ($) *</label>
              <input type="number" id="price" name="price" class="form-control" min="0" step="0.01" value="<%= listing.price %>" required>
            </div>

            <div class="col-md-6">
              <label for="module_code" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Module Code (e.g. C237) - optional</label>
              <input type="text" id="module_code" name="module_code" class="form-control" value="<%= listing.module_code || '' %>" placeholder="1 letter + 3 numbers">
              <div class="form-text small text-muted">Must follow C237 formatting format (e.g. C207, B216).</div>
            </div>
          </div>

          <div class="mb-4">
            <label for="image" class="form-label small text-uppercase tracking-wider fw-bold text-muted">Upload New Photo (optional, keeps existing if blank)</label>
            <input type="file" id="image" name="image" class="form-control" accept="image/png, image/jpeg, image/jpg">
            <% if (listing.image) { %>
              <div class="form-text small text-muted">Currently: <code><%= listing.image %></code></div>
            <% } %>
          </div>

          <div class="d-flex justify-content-end gap-2 border-top pt-3">
            <a href="/listings/<%= listing.id %>" class="btn btn-outline-secondary px-4">Cancel</a>
            <button type="submit" class="btn btn-warning fw-bold text-dark px-4">Save Changes</button>
          </div>
        </form>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
